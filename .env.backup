# ===================================
# NEWS LENS - ENVIRONMENT VARIABLES
# ===================================
# All services configured for LOCAL AI with Ollama + GPU

# ----------------------------------
# OLLAMA CONFIGURATION (Local LLM with GPU)
# ----------------------------------
# Ollama runs in Docker with GPU support
# Models should be pulled inside the Ollama container
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# LLM Model for text generation
OLLAMA_LLM_MODEL=qwen3.5:4b

# Embedding Model for vector generation
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# ----------------------------------
# CHROMADB CONFIGURATION
# ----------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=news_articles

# ----------------------------------
# RAG CONFIGURATION
# ----------------------------------
# Number of top documents to retrieve
RAG_TOP_K=5

# LLM temperature (0.0-1.0, lower = more focused)
RAG_TEMPERATURE=0.7

# Maximum tokens to generate in LLM response
RAG_MAX_TOKENS=512

# ----------------------------------
# BACKEND (FastAPI)
# ----------------------------------
BACKEND_PORT=8001
CORS_ORIGINS=https://34.40.106.96,http://34.40.106.96

# ----------------------------------
# FRONTEND (Next.js)
# ----------------------------------
NEXT_PUBLIC_API_URL=http://34.40.106.96
FRONTEND_PORT=3001
NEXT_PUBLIC_API_MODE=direct

# ----------------------------------
# GOOGLE CLOUD STORAGE (Data Lake)
# ----------------------------------
# Bucket name for storing raw and processed news data
GCS_BUCKET_NAME=newslens-data-lake

# Path to GCS service account JSON key file (mounted in Docker)
# Place key file in: ./secrets/gcs-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-service-account.json

# ----------------------------------
# AIRFLOW CONFIGURATION (ETL Pipeline)
# ----------------------------------
# Airflow Webserver port
AIRFLOW_WEBSERVER_PORT=8080

# Airflow Fernet key for encrypting secrets (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW_FERNET_KEY=Zr4u7x!A%D*G-KaPdSgVkYp3s6v9y$$B&E(H+MbQeThW

# Airflow Webserver secret key (change this for production)
AIRFLOW_SECRET_KEY=secret

# ChromaDB collection name for storing news embeddings
CHROMADB_COLLECTION=news_articles

# ----------------------------------
# RSS FEED SOURCES (Configured via Airflow Variables)
# ----------------------------------
# These are set via Airflow UI (Admin > Variables) or initialization script
# Example URLs are provided in airflow/scripts/init_airflow_variables.py
#
# Default feeds:
# - VNExpress (Vietnam): https://vnexpress.net/rss/the-gioi.rss
# - DW News (Germany): https://rss.dw.com/rdf/rss-en-top
# - VNExpress (Vietnam): https://vnexpress.net/rss/thoi-su.rss
# To add more feeds, update the NEWS_RSS_FEEDS variable in Airflow UI
