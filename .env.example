# ===================================
# NEWS LENS - ENVIRONMENT VARIABLES
# ===================================
# All services configured for LOCAL AI with Ollama + GPU

# ----------------------------------
# OLLAMA CONFIGURATION (Local LLM with GPU)
# ----------------------------------
# Ollama runs in Docker with GPU support
# Models should be pulled inside the Ollama container
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# LLM Model for text generation
OLLAMA_LLM_MODEL=qwen3.5:4b

# Embedding Model for vector generation
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# ----------------------------------
# CHROMADB CONFIGURATION
# ----------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=news_articles

# ----------------------------------
# RAG CONFIGURATION
# ----------------------------------
# Number of top documents to retrieve
RAG_TOP_K=5

# LLM temperature (0.0-1.0, lower = more focused)
RAG_TEMPERATURE=0.7

# Maximum tokens to generate in LLM response
RAG_MAX_TOKENS=500

# ----------------------------------
# BACKEND (FastAPI)
# ----------------------------------
BACKEND_PORT=8001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------
# FRONTEND (Next.js)
# ----------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8001
FRONTEND_PORT=3000

# ----------------------------------
# GOOGLE CLOUD STORAGE (Optional - for Airflow ETL)
# ----------------------------------
# GCS_BUCKET_NAME=your-gcs-bucket-name
# GCS_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account-key.json

# ----------------------------------
# AIRFLOW CONFIGURATION (Optional - for ETL)
# ----------------------------------
# AIRFLOW_UID=50000
# AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-change-this
# _AIRFLOW_WWW_USER_USERNAME=admin
# _AIRFLOW_WWW_USER_PASSWORD=admin_password_change_this

# ----------------------------------
# RSS FEED SOURCES
# ----------------------------------
# NEWS_FEED_URLS=https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml,https://feeds.bbci.co.uk/news/rss.xml
# ARTICLE_LOOKBACK_DAYS=1
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# MAX_WORKERS=5
