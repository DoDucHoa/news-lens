# ===================================
# NEWS LENS - ENVIRONMENT VARIABLES
# ===================================

# ----------------------------------
# GOOGLE CLOUD STORAGE
# ----------------------------------
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
# Path to service account JSON key file (relative or absolute)
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account-key.json

# ----------------------------------
# OPENAI API (for embeddings & LLM)
# ----------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# ----------------------------------
# GOOGLE GEMINI API (Alternative)
# ----------------------------------
# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-1.5-flash

# ----------------------------------
# CHROMADB CONFIGURATION
# ----------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# NOTE: ChromaDB runs on Docker internal network, not exposed publicly

# ----------------------------------
# AIRFLOW CONFIGURATION
# ----------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your-secret-key-change-this

# Airflow Admin User (for first-time setup)
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin_password_change_this

# ----------------------------------
# BACKEND (FastAPI)
# ----------------------------------
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------
# FRONTEND (Next.js)
# ----------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ----------------------------------
# RSS FEED SOURCES
# ----------------------------------
# Comma-separated list of news RSS feed URLs
NEWS_FEED_URLS=https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml,https://feeds.bbci.co.uk/news/rss.xml

# ----------------------------------
# DATA PIPELINE SETTINGS
# ----------------------------------
# Number of days to look back for articles
ARTICLE_LOOKBACK_DAYS=1

# Chunking settings for text splitting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Maximum number of concurrent article scrapes
MAX_WORKERS=5

# Top-K results for RAG retrieval
RAG_TOP_K=5
